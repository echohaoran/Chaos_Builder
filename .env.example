# ChaosBuilder Docker Environment
# Copy to .env and modify values for your deployment

# ───────── User-system server (port 3001) ─────────
JWT_SECRET=change-this-to-a-random-secret
CORS_ORIGIN=*
PORT=3001

# ───────── SMTP Email (for registration verification) ─────────
# 使用QQ邮箱: SMTP_HOST=smtp.qq.com, SMTP_PORT=465
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=965704308@qq.com
SMTP_PASS=yfwlxceegcvjbfcf
SMTP_FROM=965704308@qq.com

# ───────── Image API server (port 8766, api_server.py) ─────────
# 必填:不填则前端必须自带 Authorization 才能调通
PPIO_API_KEY=
# 选填:上游基址 / 端点路径,默认走 PPIO gpt-image-2
PPIO_BASE=https://api.ppio.com
PPIO_T2I_PATH=/v3/gpt-image-2-text-to-image
PPIO_I2I_PATH=/v3/gpt-image-2-image-to-image
PPIO_INPAINT_PATH=/v3/gpt-image-2-inpainting
# 选填:本机监听地址
API_HOST=0.0.0.0
API_PORT=8766
UPSTREAM_TIMEOUT=120
